---
import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"video"> {
  src: string;
}

const {
  src,
  controls = true,
  loop = true,
  playsinline = true,
  muted = true,
  autoplay = true,
  ...videoProps
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;
const resolvedSrc = src.startsWith("/") ? base + src : src;
---

<video
  class="aspect-video h-auto w-full rounded-xl shadow-lg"
  src={resolvedSrc}
  controls={controls}
  loop={loop}
  playsinline={playsinline}
  muted={muted}
  autoplay={autoplay}
  {...videoProps}></video>
